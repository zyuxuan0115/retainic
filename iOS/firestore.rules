rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read/write only their own profile and everything nested
    // beneath it (lists and words).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Cross-user READ access so a signed-in user can import a wordlist shared
    // with them by its public ID: the collection-group lookup on `publicId`
    // and the word copy both need to read another account's lists/words.
    // The recursive-wildcard prefix ({path=**}) is required to authorize the
    // collection-group query on `lists`. Writes stay owner-only (rules above).
    match /{path=**}/lists/{listId} {
      allow read: if request.auth != null;
    }
    match /{path=**}/words/{wordId} {
      allow read: if request.auth != null;
    }

    // Invitation codes used to gate registration. Each code is a document whose
    // ID is the code itself. Anyone may `get` a code they already know (to
    // verify it before signing up), but listing/enumerating and any writes are
    // forbidden — codes are added by an admin (Firebase console / Admin SDK).
    match /invitationCodes/{code} {
      allow get: if true;
      allow list, write: if false;
    }
  }
}
