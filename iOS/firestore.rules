rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read/write only their own profile and everything nested
    // beneath it (lists and words).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Invitation codes used to gate registration. Each code is a document whose
    // ID is the code itself. Anyone may `get` a code they already know (to
    // verify it before signing up), but listing/enumerating and any writes are
    // forbidden — codes are added by an admin (Firebase console / Admin SDK).
    match /invitationCodes/{code} {
      allow get: if true;
      allow list, write: if false;
    }
  }
}
